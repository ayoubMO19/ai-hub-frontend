    "/api/v1/models": {
      "get": {
        "operationId": "ModelsController_findAll",
        "parameters": [
          {
            "name": "search",
            "required": false,
            "in": "query",
            "schema": {
              "example": "claude",
              "type": "string"
            }
          },
          {
            "name": "provider",
            "required": false,
            "in": "query",
            "schema": {
              "example": "openai",
              "type": "string"
            }
          },
          {
            "name": "isOpenSource",
            "required": false,
            "in": "query",
            "schema": {
              "example": true,
              "type": "boolean"
            }
          },
          {
            "name": "isMultimodal",
            "required": false,
            "in": "query",
            "schema": {
              "example": true,
              "type": "boolean"
            }
          },
          {
            "name": "minContext",
            "required": false,
            "in": "query",
            "schema": {
              "example": 128000,
              "type": "number"
            }
          },
          {
            "name": "maxPrice",
            "required": false,
            "in": "query",
            "schema": {
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "default": 20,
              "example": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of models"
          }
        },
        "summary": "List all AI models with filters and pagination",
        "tags": [
          "Models"
        ]
      }
    },
    "/api/v1/models/{slug}": {
      "get": {
        "operationId": "ModelsController_findBySlug",
