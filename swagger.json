          {
            "name": "slug",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          },
          "404": {
            "description": "Model not found"
          }
        },
        "summary": "Get model details by slug",
        "tags": [
          "Models"
        ]
      }
    },
