  "info": {
    "title": "AI Hub API",
    "description": "\n  ## AI Models Intelligence API\n\n  REST API that aggregates and normalizes data from multiple AI model providers.\n  Real-time rankings, pricing comparisons, and model capabilities.\n\n  ### Features\n  - 🔄 Auto-sync from OpenRouter & HuggingFace every 6 hours\n  - ⚡ Redis-cached rankings (15min TTL)\n  - 🔐 JWT authentication with refresh tokens\n  - 📊 Dynamic rankings: cheapest, fastest, largest context\n\n  ### Rate limiting\n  100 requests / 60 seconds per IP\n    ",
    "version": "1.0.0",
    "contact": {
      "name": "AI Hub",
      "url": "https://github.com/ayoubMO19/ai-hub",
      "email": "ayoubmorghiouhda@gmail.com"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "tags": [],
  "servers": [
    {
      "url": "https://aihub.ayoubmorghi.com",
      "description": "Production"
    },
    {
      "url": "http://localhost:3000",
      "description": "Development"
    }
  ],
  "components": {
    "securitySchemes": {
      "JWT": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http",
        "description": "Enter your JWT access token"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "strongPassword123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
